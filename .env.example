# Local folder to sync (absolute or relative path)
LOCAL_FOLDER_PATH=./sync_folder

# Remote folder name in cloud storage
REMOTE_FOLDER_NAME=my-sync-folder

# API token for cloud authentication
API_TOKEN=your_api_token_here

# Sync interval in seconds (e.g., 300 = 5 minutes)
SYNC_INTERVAL=300

# Log file path (optional, defaults to sync_service.log)
LOG_FILE_PATH=sync_service.log

# Cloud client type: 'mock' for local testing, 'production' for real API
CLOUD_CLIENT_TYPE=mock
